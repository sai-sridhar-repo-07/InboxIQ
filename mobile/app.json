{
  "expo": {
    "name": "Mailair",
    "slug": "mailair",
    "scheme": "mailair",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "description": "AI-powered email management. Prioritise, summarise, reply and track revenue — all from one inbox.",
    "privacy": "public",
    "ios": {
      "bundleIdentifier": "com.mailair.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Not used.",
        "NSPhotoLibraryUsageDescription": "Not used.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "mailair"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.mailair.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "mailair"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Mailair to use Face ID for secure sign-in."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "privacyPolicyUrl": "https://mailair.company/privacy",
      "termsUrl": "https://mailair.company/terms",
      "eas": {
        "projectId": "c681bdd8-bea6-4cde-b2b0-f4909574c1b5"
      }
    },
    "owner": "sai_sridhar_tarra",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c681bdd8-bea6-4cde-b2b0-f4909574c1b5"
    }
  }
}
