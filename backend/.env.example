# ===========================
# INBOXIQ BACKEND CONFIG
# ===========================
# Copy this file to .env and fill in real values before running locally.
# Never commit .env to version control.

# ---------------------------
# Supabase
# ---------------------------
# Project URL from: Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe to expose to clients, enforces RLS
# Supabase Dashboard -> Settings -> API -> Project API keys -> anon / public
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — KEEP SECRET, bypasses RLS, backend use only
# Supabase Dashboard -> Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ---------------------------
# Anthropic / Claude
# ---------------------------
# console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---------------------------
# Gmail OAuth 2.0
# ---------------------------
# console.cloud.google.com -> Credentials -> OAuth 2.0 Client IDs
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Must match exactly what's registered in Google Cloud Console
# Dev: http://localhost:8000/integrations/gmail/callback
# Prod: https://your-render-url.onrender.com/integrations/gmail/callback
GMAIL_REDIRECT_URI=http://localhost:8000/integrations/gmail/callback

# ---------------------------
# Slack
# ---------------------------
# api.slack.com -> Your Apps -> Incoming Webhooks
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ---------------------------
# Stripe
# ---------------------------
# dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Price IDs from Stripe Dashboard -> Products
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here
STRIPE_AGENCY_PRICE_ID=price_your_agency_price_id_here

# ---------------------------
# Security / JWT
# ---------------------------
# Random secret for signing internal tokens — minimum 32 characters
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ---------------------------
# Application Settings
# ---------------------------
# 'development' | 'staging' | 'production'
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# Dev: http://localhost:3000
# Prod: https://your-vercel-url.vercel.app
CORS_ORIGINS=http://localhost:3000

# Max emails to process per background job run
MAX_EMAILS_PER_SYNC=50

# Urgency score threshold (1-10) above which Slack alerts are sent
URGENCY_THRESHOLD=7
